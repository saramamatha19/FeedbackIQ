# PostgreSQL — local install, e.g. postgresql://feedbackiq:feedbackiq@localhost:5432/feedbackiq
DATABASE_URL=postgresql://feedbackiq:feedbackiq@localhost:5432/feedbackiq

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — frontend dev origin
FRONTEND_ORIGIN=http://localhost:5173

# Environment
ENV=development
